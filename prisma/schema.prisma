  formulaVersion   FormulaVersion @relation(fields: [formulaVersionId], references: [id])
  prescription     Prescription?  @relation(fields: [prescriptionId], references: [id])
  compounder       User           @relation("BatchCompounder", fields: [compoundedBy], references: [id])
  verifier         User?          @relation("BatchVerifier", fields: [verifiedBy], references: [id])

  ingredients      BatchIngredient[]
