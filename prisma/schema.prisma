generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// STORE & SETTINGS
// ═══════════════════════════════════════════════

model Store {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(255)
  npi           String?  @db.VarChar(10)
  dea           String?  @db.VarChar(15)
  stateLicense  String?  @map("state_license") @db.VarChar(30)
  phone         String?  @db.VarChar(20)
  fax           String?  @db.VarChar(20)
  email         String?  @db.VarChar(255)
  addressLine1  String?  @map("address_line_1") @db.VarChar(255)
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(2)
  zip           String?  @db.VarChar(10)
  timezone      String   @default("America/Chicago") @db.VarChar(50)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  
  settings      StoreSetting[]
  users         User[]
  userRoles     UserRole[]

  @@map("stores")
}

model StoreSetting {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  settingKey   String   @map("setting_key") @db.VarChar(100)
  settingValue String   @map("setting_value") @db.Text
  settingType  String   @default("string") @map("setting_type") @db.VarChar(20)
  updatedBy    String?  @map("updated_by") @db.Uuid
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz
  
  store        Store    @relation(fields: [storeId], references: [id])
  updater      User?    @relation("SettingUpdater", fields: [updatedBy], references: [id])

  @@unique([storeId, settingKey])
  @@map("store_settings")
}

// ═══════════════════════════════════════════════
// USERS & AUTH
// ═══════════════════════════════════════════════

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseId      String    @unique @map("supabase_id") @db.VarChar(255)
  externalId      String?   @map("external_id") @db.VarChar(50)
  email           String    @unique @db.VarChar(255)
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  phone           String?   @db.VarChar(20)
  department      String?   @db.VarChar(50)
  isPharmacist    Boolean   @default(false) @map("is_pharmacist")
  licenseNumber   String?   @map("license_number") @db.VarChar(50)
  pin             String?   @db.VarChar(255)
  isActive        Boolean   @default(true) @map("is_active")
  lastLogin       DateTime? @map("last_login") @db.Timestamptz
  storeId         String?   @map("store_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  store           Store?    @relation(fields: [storeId], references: [id])
  roles           UserRole[]

  // Reverse relations
  settingsUpdated  StoreSetting[] @relation("SettingUpdater")
  patientsCreated  Patient[]      @relation("PatientCreator")
  patientsUpdated  Patient[]      @relation("PatientUpdater")
  allergiesVerified PatientAllergy[] @relation("AllergyVerifier")
  outsideMedsCreated PatientOutsideMed[] @relation("OutsideMedCreator")
  encountersCreated PatientMedicalEncounter[] @relation("EncounterCreator")
  customStatusesCreated PatientCustomStatus[] @relation("CustomStatusCreator")
  rxCreated        Prescription[] @relation("RxCreator")
  rxAssigned       Prescription[] @relation("RxAssignee")
  fillsFilled      PrescriptionFill[] @relation("FillFiller")
  fillsVerified    PrescriptionFill[] @relation("FillVerifier")
  fillEventsPerformed FillEvent[] @relation("FillEventPerformer")
  statusChanges    PrescriptionStatusLog[] @relation("StatusChanger")
  intakeAssigned   IntakeQueueItem[] @relation("IntakeAssignee")
  intakeCreated    IntakeQueueItem[] @relation("IntakeCreator")
  refillsProcessed RefillRequest[] @relation("RefillProcessor")
  renewalsCreated  Renewal[] @relation("RenewalCreator")
  transfersCreated Transfer[] @relation("TransferCreator")
  eligibilityChecked EligibilityCheck[] @relation("EligibilityChecker")
  batchesCompounded Batch[] @relation("BatchCompounder")
  batchesVerified  Batch[] @relation("BatchVerifier")
  batchIngredientsWeighed BatchIngredient[] @relation("IngredientWeigher")
  batchQaPerformed BatchQa[] @relation("QaPerformer")
  invTransactions  InventoryTransaction[] @relation("InvTransactor")
  shipmentsShipped Shipment[] @relation("ShipmentShipper")
  deliveriesAssigned Delivery[] @relation("DeliveryDriver")
  routesAssigned   DeliveryRoute[] @relation("RouteDriver")
  posSessionsOpened PosSession[] @relation("PosOpener")
  posSessionsClosed PosSession[] @relation("PosCloser")
  posTransactions  PosTransaction[] @relation("PosCashier")
  commsSent        CommunicationLog[] @relation("CommSender")
  documentsUploaded Document[] @relation("DocUploader")
  commentsCreated  Comment[] @relation("CommentAuthor")
  entityTagsCreated EntityTag[] @relation("TagCreator")
  todosCreated     Todo[] @relation("TodoCreator")
  todosAssigned    Todo[] @relation("TodoAssignee")
  todosCompleted   Todo[] @relation("TodoCompleter")
  tasksCreated     Task[] @relation("TaskCreator")
  webhooksCreated  Webhook[] @relation("WebhookCreator")
  chargeTransCreated ChargeAccountTransaction[] @relation("ChargeTransCreator")
  paymentsProcessed Payment[] @relation("PaymentProcessor")
  formulaVersionsCreated FormulaVersion[] @relation("FormulaVersionCreator")
  auditLogs        AuditLog[]

  @@map("users")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @unique @db.VarChar(50)
  description String?    @db.VarChar(255)
  permissions Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  storeId   String?  @map("store_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  store     Store?   @relation(fields: [storeId], references: [id])

  @@unique([userId, roleId, storeId])
  @@map("user_roles")
}

// ═══════════════════════════════════════════════
// FACILITIES (LTC)
// ═══════════════════════════════════════════════

model Facility {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  fax          String?  @db.VarChar(20)
  addressLine1 String?  @map("address_line_1") @db.VarChar(255)
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(2)
  zip          String?  @db.VarChar(10)
  contactName  String?  @map("contact_name") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  wings        FacilityWing[]
  patients     Patient[]

  @@map("facilities")
}

model FacilityWing {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facilityId String   @map("facility_id") @db.Uuid
  name       String   @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")

  facility   Facility @relation(fields: [facilityId], references: [id])
  rooms      FacilityRoom[]
  patients   Patient[]

  @@map("facility_wings")
}

model FacilityRoom {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wingId     String   @map("wing_id") @db.Uuid
  roomNumber String   @map("room_number") @db.VarChar(20)
  bedCount   Int      @default(1) @map("bed_count")
  isActive   Boolean  @default(true) @map("is_active")

  wing       FacilityWing @relation(fields: [wingId], references: [id])
  patients   Patient[]

  @@map("facility_rooms")
}

// ═══════════════════════════════════════════════
// PATIENTS
// ═══════════════════════════════════════════════

model Patient {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mrn              String    @unique @db.VarChar(20)
  externalId       String?   @map("external_id") @db.VarChar(50)
  firstName        String    @map("first_name") @db.VarChar(100)
  middleName       String?   @map("middle_name") @db.VarChar(100)
  lastName         String    @map("last_name") @db.VarChar(100)
  suffix           String?   @db.VarChar(20)
  dateOfBirth      DateTime  @map("date_of_birth") @db.Date
  gender           String?   @db.VarChar(20)
  ssnLastFour      String?   @map("ssn_last_four") @db.VarChar(4)
  email            String?   @db.VarChar(255)
  preferredContact String    @default("phone") @map("preferred_contact") @db.VarChar(20)
  preferredLanguage String   @default("en") @map("preferred_language") @db.VarChar(20)
  status           String    @default("active") @db.VarChar(20)
  facilityId       String?   @map("facility_id") @db.Uuid
  wingId           String?   @map("wing_id") @db.Uuid
  roomId           String?   @map("room_id") @db.Uuid
  notes            String?   @db.Text
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid

  facility         Facility?     @relation(fields: [facilityId], references: [id])
  wing             FacilityWing? @relation(fields: [wingId], references: [id])
  room             FacilityRoom? @relation(fields: [roomId], references: [id])
  creator          User?         @relation("PatientCreator", fields: [createdBy], references: [id])
  updater          User?         @relation("PatientUpdater", fields: [updatedBy], references: [id])

  phoneNumbers     PatientPhoneNumber[]
  addresses        PatientAddress[]
  allergies        PatientAllergy[]
  insurance        PatientInsurance[]
  outsideMeds      PatientOutsideMed[]
  encounters       PatientMedicalEncounter[]
  customStatuses   PatientCustomStatus[]
  syncLists        PatientSyncList[]
  prescriptions    Prescription[]
  refillRequests   RefillRequest[]
  chargeAccounts   ChargeAccount[]
  shipments        Shipment[]
  deliveries       Delivery[]
  posTransactions  PosTransaction[]
  communications   CommunicationLog[] @relation("PatientComms")
  payments         Payment[]

  @@index([lastName])
  @@index([dateOfBirth])
  @@index([externalId])
  @@map("patients")
}

model PatientPhoneNumber {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId  String   @map("patient_id") @db.Uuid
  phoneType  String   @map("phone_type") @db.VarChar(20)
  number     String   @db.VarChar(20)
  extension  String?  @db.VarChar(10)
  isPrimary  Boolean  @default(false) @map("is_primary")
  acceptsSms Boolean  @default(false) @map("accepts_sms")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_phone_numbers")
}

model PatientAddress {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  addressType String   @map("address_type") @db.VarChar(20)
  line1       String   @map("line_1") @db.VarChar(255)
  line2       String?  @map("line_2") @db.VarChar(255)
  city        String   @db.VarChar(100)
  state       String   @db.VarChar(2)
  zip         String   @db.VarChar(10)
  country     String   @default("US") @db.VarChar(2)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  shipments   Shipment[]
  deliveries  Delivery[]

  @@map("patient_addresses")
}

model PatientAllergy {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String    @map("patient_id") @db.Uuid
  allergen     String    @db.VarChar(255)
  allergenCode String?   @map("allergen_code") @db.VarChar(20)
  reaction     String?   @db.VarChar(255)
  severity     String    @db.VarChar(20)
  onsetDate    DateTime? @map("onset_date") @db.Date
  status       String    @default("active") @db.VarChar(20)
  source       String?   @db.VarChar(50)
  verifiedBy   String?   @map("verified_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  verifier     User?     @relation("AllergyVerifier", fields: [verifiedBy], references: [id])

  @@map("patient_allergies")
}

model PatientInsurance {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String    @map("patient_id") @db.Uuid
  thirdPartyPlanId   String?   @map("third_party_plan_id") @db.Uuid
  priority           String    @db.VarChar(20)
  memberId           String    @map("member_id") @db.VarChar(50)
  personCode         String?   @map("person_code") @db.VarChar(10)
  groupNumber        String?   @map("group_number") @db.VarChar(30)
  relationship       String?   @db.VarChar(20)
  cardholderName     String?   @map("cardholder_name") @db.VarChar(255)
  cardholderId       String?   @map("cardholder_id") @db.VarChar(50)
  effectiveDate      DateTime? @map("effective_date") @db.Date
  terminationDate    DateTime? @map("termination_date") @db.Date
  isActive           Boolean   @default(true) @map("is_active")
  lastEligibilityCheck DateTime? @map("last_eligibility_check") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  thirdPartyPlan     ThirdPartyPlan? @relation(fields: [thirdPartyPlanId], references: [id])
  prescriptions      Prescription[]
  claims             Claim[]
  eligibilityChecks  EligibilityCheck[]

  @@map("patient_insurance")
}

model PatientOutsideMed {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  medicationName String    @map("medication_name") @db.VarChar(255)
  ndc            String?   @db.VarChar(15)
  strength       String?   @db.VarChar(100)
  directions     String?   @db.Text
  prescriberName String?   @map("prescriber_name") @db.VarChar(255)
  pharmacyName   String?   @map("pharmacy_name") @db.VarChar(255)
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy      String?   @map("created_by") @db.Uuid

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  creator        User?     @relation("OutsideMedCreator", fields: [createdBy], references: [id])

  @@map("patient_outside_meds")
}

model PatientMedicalEncounter {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  encounterDate DateTime  @map("encounter_date") @db.Date
  icd10Code     String?   @map("icd10_code") @db.VarChar(10)
  diagnosis     String?   @db.VarChar(255)
  prescriberId  String?   @map("prescriber_id") @db.Uuid
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy     String?   @map("created_by") @db.Uuid

  patient       Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriber    Prescriber? @relation(fields: [prescriberId], references: [id])
  creator       User?      @relation("EncounterCreator", fields: [createdBy], references: [id])

  @@map("patient_medical_encounters")
}

model PatientCustomStatus {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  statusName  String   @map("status_name") @db.VarChar(100)
  statusValue String?  @map("status_value") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  creator     User?    @relation("CustomStatusCreator", fields: [createdBy], references: [id])

  @@map("patient_custom_statuses")
}

model PatientSyncList {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId      String   @map("patient_id") @db.Uuid
  prescriptionId String   @map("prescription_id") @db.Uuid
  syncDate       DateTime? @map("sync_date") @db.Date
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  @@map("patient_sync_lists")
}

// ═══════════════════════════════════════════════
// PRESCRIBERS / DOCTORS
// ═══════════════════════════════════════════════

model Prescriber {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId       String?  @map("external_id") @db.VarChar(50)
  npi              String   @unique @db.VarChar(10)
  deaNumber        String?  @unique @map("dea_number") @db.VarChar(15)
  firstName        String   @map("first_name") @db.VarChar(100)
  middleName       String?  @map("middle_name") @db.VarChar(100)
  lastName         String   @map("last_name") @db.VarChar(100)
  suffix           String?  @db.VarChar(20)
  specialty        String?  @db.VarChar(100)
  phone            String?  @db.VarChar(20)
  fax              String?  @db.VarChar(20)
  email            String?  @db.VarChar(255)
  addressLine1     String?  @map("address_line_1") @db.VarChar(255)
  city             String?  @db.VarChar(100)
  state            String?  @db.VarChar(2)
  zip              String?  @db.VarChar(10)
  stateLicense     String?  @map("state_license") @db.VarChar(30)
  licenseState     String?  @map("license_state") @db.VarChar(2)
  scheduleAuthority Json    @default("[]") @map("schedule_authority")
  isActive         Boolean  @default(true) @map("is_active")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  prescriptions    Prescription[]
  encounters       PatientMedicalEncounter[]
  renewals         Renewal[]
  communications   CommunicationLog[] @relation("PrescriberComms")

  @@index([lastName])
  @@index([externalId])
  @@map("prescribers")
}

// ═══════════════════════════════════════════════
// ITEMS / DRUG CATALOG
// ═══════════════════════════════════════════════

model Item {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId           String?  @map("external_id") @db.VarChar(50)
  ndc                  String?  @db.VarChar(15)
  name                 String   @db.VarChar(255)
  genericName          String?  @map("generic_name") @db.VarChar(255)
  brandName            String?  @map("brand_name") @db.VarChar(255)
  manufacturer         String?  @db.VarChar(255)
  strength             String?  @db.VarChar(100)
  dosageForm           String?  @map("dosage_form") @db.VarChar(100)
  route                String?  @db.VarChar(100)
  packageSize          String?  @map("package_size") @db.VarChar(50)
  unitOfMeasure        String?  @map("unit_of_measure") @db.VarChar(20)
  awp                  Decimal? @db.Decimal(10, 2)
  acquisitionCost      Decimal? @map("acquisition_cost") @db.Decimal(10, 2)
  isCompoundIngredient Boolean  @default(false) @map("is_compound_ingredient")
  isOtc                Boolean  @default(false) @map("is_otc")
  isControlled         Boolean  @default(false) @map("is_controlled")
  deaSchedule          String?  @map("dea_schedule") @db.VarChar(5)
  isRefrigerated       Boolean  @default(false) @map("is_refrigerated")
  reorderPoint         Decimal? @map("reorder_point") @db.Decimal(10, 2)
  reorderQuantity      Decimal? @map("reorder_quantity") @db.Decimal(10, 2)
  isActive             Boolean  @default(true) @map("is_active")
  metadata             Json     @default("{}")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  lots                 ItemLot[]
  formulaIngredients   FormulaIngredient[]
  prescriptions        Prescription[]
  fills                PrescriptionFill[]
  posLineItems         PosLineItem[]

  @@index([ndc])
  @@index([externalId])
  @@map("items")
}

model Supplier {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  contactName  String?  @map("contact_name") @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(255)
  accountNumber String? @map("account_number") @db.VarChar(50)
  paymentTerms String?  @map("payment_terms") @db.VarChar(100)
  leadTimeDays Int?     @map("lead_time_days")
  isActive     Boolean  @default(true) @map("is_active")

  lots         ItemLot[]

  @@map("suppliers")
}

model ItemLot {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId           String    @map("item_id") @db.Uuid
  lotNumber        String    @map("lot_number") @db.VarChar(50)
  supplierId       String?   @map("supplier_id") @db.Uuid
  quantityReceived Decimal   @map("quantity_received") @db.Decimal(10, 2)
  quantityOnHand   Decimal   @map("quantity_on_hand") @db.Decimal(10, 2)
  unit             String    @db.VarChar(20)
  unitCost         Decimal?  @map("unit_cost") @db.Decimal(10, 4)
  expirationDate   DateTime  @map("expiration_date") @db.Date
  dateReceived     DateTime  @map("date_received") @db.Date
  coaDocumentId    String?   @map("coa_document_id") @db.Uuid
  status           String    @default("available") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  item             Item      @relation(fields: [itemId], references: [id])
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  coaDocument      Document? @relation(fields: [coaDocumentId], references: [id])

  transactions     InventoryTransaction[]
  fills            PrescriptionFill[]
  batchIngredients BatchIngredient[]

  @@index([expirationDate])
  @@index([itemId, status])
  @@map("item_lots")
}

model InventoryTransaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemLotId       String   @map("item_lot_id") @db.Uuid
  transactionType String   @map("transaction_type") @db.VarChar(30)
  quantity        Decimal  @db.Decimal(10, 2)
  referenceType   String?  @map("reference_type") @db.VarChar(50)
  referenceId     String?  @map("reference_id") @db.Uuid
  performedBy     String   @map("performed_by") @db.Uuid
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

