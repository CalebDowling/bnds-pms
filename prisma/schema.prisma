  sortOrder        Int      @default(0) @map("sort_order")

  formulaVersion   FormulaVersion @relation(fields: [formulaVersionId], references: [id], onDelete: Cascade)
  item             Item           @relation(fields: [itemId], references: [id])

  @@map("formula_ingredients")
}

model FormulaStep {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  formulaVersionId String   @map("formula_version_id") @db.Uuid
