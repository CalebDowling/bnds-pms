// ═══════════════════════════════════════════════

model Formula {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String    @db.VarChar(255)
  formulaCode      String    @unique @map("formula_code") @db.VarChar(50)
  category         String?   @db.VarChar(100)
  dosageForm       String?   @map("dosage_form") @db.VarChar(100)
  route            String?   @db.VarChar(100)
  isSterile        Boolean   @default(false) @map("is_sterile")
  defaultBudDays   Int?      @map("default_bud_days")
  storageConditions String?  @map("storage_conditions") @db.VarChar(255)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  versions         FormulaVersion[]
  prescriptions    Prescription[]

  @@map("formulas")
}

model FormulaVersion {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  formulaId     String    @map("formula_id") @db.Uuid
  versionNumber Int       @map("version_number")
  effectiveDate DateTime  @map("effective_date") @db.Date
  baseCost      Decimal?  @map("base_cost") @db.Decimal(10, 4)
  price         Decimal?  @db.Decimal(10, 2)
  pricingMethod String?   @map("pricing_method") @db.VarChar(30)
  notes         String?   @db.Text
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  formula       Formula   @relation(fields: [formulaId], references: [id])
  creator       User?     @relation("FormulaVersionCreator", fields: [createdBy], references: [id])

  ingredients   FormulaIngredient[]
  steps         FormulaStep[]
  batches       Batch[]

  @@unique([formulaId, versionNumber])
  @@map("formula_versions")
}

model FormulaIngredient {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  formulaVersionId String   @map("formula_version_id") @db.Uuid
  itemId           String   @map("item_id") @db.Uuid
  quantity         Decimal  @db.Decimal(12, 4)
  unit             String   @db.VarChar(20)
