  requiresPharmacist Boolean @default(false) @map("requires_pharmacist")
  imageDocumentId  String?  @map("image_document_id") @db.Uuid

  formulaVersion   FormulaVersion @relation(fields: [formulaVersionId], references: [id], onDelete: Cascade)

  @@map("formula_steps")
}

model Batch {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchNumber      String    @unique @map("batch_number") @db.VarChar(30)
  formulaVersionId String    @map("formula_version_id") @db.Uuid
  prescriptionId   String?   @map("prescription_id") @db.Uuid
  quantityPrepared Decimal   @map("quantity_prepared") @db.Decimal(10, 2)
  unit             String    @db.VarChar(20)
  budDate          DateTime  @map("bud_date") @db.Date
  status           String    @db.VarChar(20)
  compoundedBy     String    @map("compounded_by") @db.Uuid
  verifiedBy       String?   @map("verified_by") @db.Uuid
  compoundedAt     DateTime? @map("compounded_at") @db.Timestamptz
  verifiedAt       DateTime? @map("verified_at") @db.Timestamptz
  envTemp          Decimal?  @map("env_temp") @db.Decimal(5, 2)
