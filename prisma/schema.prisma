  itemId             String?   @map("item_id") @db.Uuid
  formulaId          String?   @map("formula_id") @db.Uuid
  isCompound         Boolean   @default(false) @map("is_compound")
  quantityPrescribed Decimal?  @map("quantity_prescribed") @db.Decimal(10, 2)
  quantityDispensed  Decimal?  @map("quantity_dispensed") @db.Decimal(10, 2)
  daysSupply         Int?      @map("days_supply")
  directions         String?   @db.Text
  dawCode            String?   @map("daw_code") @db.VarChar(2)
  refillsAuthorized  Int       @default(0) @map("refills_authorized")
  refillsRemaining   Int       @default(0) @map("refills_remaining")
  dateWritten        DateTime  @map("date_written") @db.Date
  dateReceived       DateTime  @default(now()) @map("date_received") @db.Timestamptz
  dateFilled         DateTime? @map("date_filled") @db.Timestamptz
  dateShipped        DateTime? @map("date_shipped") @db.Timestamptz
  expirationDate     DateTime? @map("expiration_date") @db.Date
  prescriberNotes    String?   @map("prescriber_notes") @db.Text
  internalNotes      String?   @map("internal_notes") @db.Text
  insuranceId        String?   @map("insurance_id") @db.Uuid
  assignedTo         String?   @map("assigned_to") @db.Uuid
  isActive           Boolean   @default(true) @map("is_active")
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy          String?   @map("created_by") @db.Uuid

  patient            Patient          @relation(fields: [patientId], references: [id])
