  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  packedAt          DateTime? @map("packed_at") @db.Timestamptz

  items             PackingListItem[]
  shipments         Shipment[]

  @@map("packing_lists")
}

model PackingListItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packingListId String    @map("packing_list_id") @db.Uuid
  fillId        String    @map("fill_id") @db.Uuid
  verified      Boolean   @default(false)
  verifiedAt    DateTime? @map("verified_at") @db.Timestamptz

  packingList   PackingList      @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  fill          PrescriptionFill @relation(fields: [fillId], references: [id])

  @@map("packing_list_items")
}

model Shipment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId      String?   @map("external_id") @db.VarChar(50)
  packingListId   String?   @map("packing_list_id") @db.Uuid
  patientId       String    @map("patient_id") @db.Uuid
  carrier         String    @db.VarChar(20)
  serviceLevel    String?   @map("service_level") @db.VarChar(50)
  trackingNumber  String?   @map("tracking_number") @db.VarChar(100)
  labelUrl        String?   @map("label_url") @db.VarChar(500)
  shippingCost    Decimal?  @map("shipping_cost") @db.Decimal(8, 2)
  weightOz        Decimal?  @map("weight_oz") @db.Decimal(8, 2)
  shipDate        DateTime? @map("ship_date") @db.Timestamptz
  estimatedDelivery DateTime? @map("estimated_delivery") @db.Date
  actualDelivery  DateTime? @map("actual_delivery") @db.Timestamptz
  status          String    @db.VarChar(20)
  requiresColdChain Boolean @default(false) @map("requires_cold_chain")
  requiresSignature Boolean @default(false) @map("requires_signature")
  addressId       String?   @map("address_id") @db.Uuid
  shippedBy       String?   @map("shipped_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  packingList     PackingList?    @relation(fields: [packingListId], references: [id])
  patient         Patient         @relation(fields: [patientId], references: [id])
  address         PatientAddress? @relation(fields: [addressId], references: [id])
  shipper         User?           @relation("ShipmentShipper", fields: [shippedBy], references: [id])

  @@index([trackingNumber])
  @@map("shipments")
}

model DeliveryRoute {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeName   String    @map("route_name") @db.VarChar(100)
  routeDate   DateTime  @map("route_date") @db.Date
  driverId    String?   @map("driver_id") @db.Uuid
  status      String    @db.VarChar(20)
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  driver      User?      @relation("RouteDriver", fields: [driverId], references: [id])
  deliveries  Delivery[]

  @@map("delivery_routes")
}

model Delivery {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId      String?   @map("route_id") @db.Uuid
  patientId    String    @map("patient_id") @db.Uuid
  addressId    String    @map("address_id") @db.Uuid
  status       String    @db.VarChar(20)
  driverId     String?   @map("driver_id") @db.Uuid
  signatureUrl String?   @map("signature_url") @db.VarChar(500)
  photoUrl     String?   @map("photo_url") @db.VarChar(500)
  deliveredAt  DateTime? @map("delivered_at") @db.Timestamptz
  notes        String?   @db.Text
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  route        DeliveryRoute?  @relation(fields: [routeId], references: [id])
  patient      Patient         @relation(fields: [patientId], references: [id])
  address      PatientAddress  @relation(fields: [addressId], references: [id])
  driver       User?           @relation("DeliveryDriver", fields: [driverId], references: [id])

  @@map("deliveries")
}

// ═══════════════════════════════════════════════
// POINT OF SALE
// ═══════════════════════════════════════════════

model PosSession {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  registerId     String    @map("register_id") @db.VarChar(20)
  openedBy       String    @map("opened_by") @db.Uuid
  closedBy       String?   @map("closed_by") @db.Uuid
  openedAt       DateTime  @map("opened_at") @db.Timestamptz
  closedAt       DateTime? @map("closed_at") @db.Timestamptz
  openingBalance Decimal   @map("opening_balance") @db.Decimal(10, 2)
  closingBalance Decimal?  @map("closing_balance") @db.Decimal(10, 2)
  status         String    @db.VarChar(20)

  opener         User      @relation("PosOpener", fields: [openedBy], references: [id])
  closer         User?     @relation("PosCloser", fields: [closedBy], references: [id])

  transactions   PosTransaction[]

  @@map("pos_sessions")
}

model PosTransaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId      String?  @map("external_id") @db.VarChar(50)
  sessionId       String   @map("session_id") @db.Uuid
  patientId       String?  @map("patient_id") @db.Uuid
  transactionType String   @map("transaction_type") @db.VarChar(20)
  subtotal        Decimal  @db.Decimal(10, 2)
  tax             Decimal  @default(0) @db.Decimal(10, 2)
  discount        Decimal  @default(0) @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  paymentMethod   String   @map("payment_method") @db.VarChar(20)
  cardLastFour    String?  @map("card_last_four") @db.VarChar(4)
  isPseSale       Boolean  @default(false) @map("is_pse_sale")
  processedBy     String   @map("processed_by") @db.Uuid
  processedAt     DateTime @default(now()) @map("processed_at") @db.Timestamptz
  click2payUrl    String?  @map("click2pay_url") @db.VarChar(500)

  session         PosSession @relation(fields: [sessionId], references: [id])
  patient         Patient?   @relation(fields: [patientId], references: [id])
  cashier         User       @relation("PosCashier", fields: [processedBy], references: [id])

  lineItems       PosLineItem[]
  payments        Payment[]

  @@map("pos_transactions")
}

model PosLineItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  itemType      String   @map("item_type") @db.VarChar(20)
  fillId        String?  @map("fill_id") @db.Uuid
  itemId        String?  @map("item_id") @db.Uuid
  description   String   @db.VarChar(255)
  quantity      Decimal  @db.Decimal(10, 2)
  unitPrice     Decimal  @map("unit_price") @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  barcode       String?  @db.VarChar(50)

  transaction   PosTransaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fill          PrescriptionFill? @relation(fields: [fillId], references: [id])
  item          Item?             @relation(fields: [itemId], references: [id])

  @@map("pos_line_items")
}

// ═══════════════════════════════════════════════
// COMMUNICATIONS
// ═══════════════════════════════════════════════

model CommunicationLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel         String    @db.VarChar(20)
  direction       String    @db.VarChar(10)
  patientId       String?   @map("patient_id") @db.Uuid
  prescriberId    String?   @map("prescriber_id") @db.Uuid
  fromAddress     String?   @map("from_address") @db.VarChar(255)
  toAddress       String    @map("to_address") @db.VarChar(255)
  subject         String?   @db.VarChar(255)
  body            String?   @db.Text
  status          String    @db.VarChar(20)
  templateName    String?   @map("template_name") @db.VarChar(100)
  documentId      String?   @map("document_id") @db.Uuid
  durationSeconds Int?      @map("duration_seconds")
  recordingUrl    String?   @map("recording_url") @db.VarChar(500)
  externalId      String?   @map("external_id") @db.VarChar(100)
  sentBy          String?   @map("sent_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  patient         Patient?    @relation("PatientComms", fields: [patientId], references: [id])
  prescriber      Prescriber? @relation("PrescriberComms", fields: [prescriberId], references: [id])
  document        Document?   @relation(fields: [documentId], references: [id])
  sender          User?       @relation("CommSender", fields: [sentBy], references: [id])

  @@index([channel])
  @@map("communication_log")
}

// ═══════════════════════════════════════════════
// DOCUMENTS & IMAGES
// ═══════════════════════════════════════════════

model Document {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileName      String   @map("file_name") @db.VarChar(255)
  fileType      String   @map("file_type") @db.VarChar(50)
  fileSizeBytes BigInt?  @map("file_size_bytes")
  storageUrl    String   @map("storage_url") @db.VarChar(500)
  thumbnailUrl  String?  @map("thumbnail_url") @db.VarChar(500)
  entityType    String   @map("entity_type") @db.VarChar(50)
  entityId      String   @map("entity_id") @db.Uuid
  documentType  String?  @map("document_type") @db.VarChar(50)
  description   String?  @db.VarChar(255)
  uploadedBy    String?  @map("uploaded_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  uploader      User?    @relation("DocUploader", fields: [uploadedBy], references: [id])

  itemLots      ItemLot[]
  communications CommunicationLog[]

  @@index([entityType, entityId])
  @@map("documents")
}

// ═══════════════════════════════════════════════
// COMMENTS & TAGS
// ═══════════════════════════════════════════════

model Comment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  body       String   @db.Text
  isInternal Boolean  @default(true) @map("is_internal")
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  author     User     @relation("CommentAuthor", fields: [createdBy], references: [id])

  @@index([entityType, entityId])
  @@map("comments")
}

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(100)
  color     String?  @db.VarChar(7)
  tagType   String   @map("tag_type") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  entityTags EntityTag[]

  @@map("tags")
}

model EntityTag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  createdBy  String?  @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  creator    User?    @relation("TagCreator", fields: [createdBy], references: [id])

  @@unique([tagId, entityType, entityId])
  @@map("entity_tags")
}

// ═══════════════════════════════════════════════
// TODOS & TASKS
// ═══════════════════════════════════════════════

model Todo {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  priority    String    @default("normal") @db.VarChar(10)
  status      String    @default("open") @db.VarChar(20)
  dueDate     DateTime? @map("due_date") @db.Date
  assignedTo  String?   @map("assigned_to") @db.Uuid
  entityType  String?   @map("entity_type") @db.VarChar(50)
  entityId    String?   @map("entity_id") @db.Uuid
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  completedBy String?   @map("completed_by") @db.Uuid
  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  creator     User      @relation("TodoCreator", fields: [createdBy], references: [id])
  assignee    User?     @relation("TodoAssignee", fields: [assignedTo], references: [id])
  completer   User?     @relation("TodoCompleter", fields: [completedBy], references: [id])

  @@map("todos")
}

model Task {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskType     String    @map("task_type") @db.VarChar(100)
  status       String    @db.VarChar(20)
  progressPct  Int       @default(0) @map("progress_pct")
  inputData    Json?     @map("input_data")
  resultData   Json?     @map("result_data")
  errorMessage String?   @map("error_message") @db.Text
  startedAt    DateTime? @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  createdBy    String    @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  creator      User      @relation("TaskCreator", fields: [createdBy], references: [id])

  @@map("tasks")
}

// ═══════════════════════════════════════════════
// WEBHOOKS
// ═══════════════════════════════════════════════

model Webhook {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url       String   @db.VarChar(500)
  events    Json
  secret    String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  creator   User?        @relation("WebhookCreator", fields: [createdBy], references: [id])
  logs      WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookId      String   @map("webhook_id") @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(100)
  payload        Json
  responseStatus Int?     @map("response_status")
  responseBody   String?  @map("response_body") @db.Text
  deliveredAt    DateTime @default(now()) @map("delivered_at") @db.Timestamptz
  retryCount     Int      @default(0) @map("retry_count")

  webhook        Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

// ═══════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(10)
  tableName String   @map("table_name") @db.VarChar(100)
  recordId  String   @map("record_id") @db.Uuid
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("audit_log")
}
