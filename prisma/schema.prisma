  refillRequests     RefillRequest[]
  renewals           Renewal[]
  transfers          Transfer[]
  batches            Batch[]
  intakeItems        IntakeQueueItem[]

  @@index([status])
  @@index([patientId])
  @@index([dateReceived])
  @@index([externalId])
  @@map("prescriptions")
}

model PrescriptionFill {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId     String?   @map("external_id") @db.VarChar(50)
  prescriptionId String    @map("prescription_id") @db.Uuid
