  itemLotId      String?   @map("item_lot_id") @db.Uuid
  ndc            String?   @db.VarChar(15)
  quantity       Decimal   @db.Decimal(10, 2)
  daysSupply     Int?      @map("days_supply")
  status         String    @db.VarChar(20)
  binLocation    String?   @map("bin_location") @db.VarChar(50)
  copayAmount    Decimal?  @map("copay_amount") @db.Decimal(10, 2)
  ingredientCost Decimal?  @map("ingredient_cost") @db.Decimal(10, 2)
  dispensingFee  Decimal?  @map("dispensing_fee") @db.Decimal(10, 2)
  totalPrice     Decimal?  @map("total_price") @db.Decimal(10, 2)
  filledBy       String?   @map("filled_by") @db.Uuid
  verifiedBy     String?   @map("verified_by") @db.Uuid
  filledAt       DateTime? @map("filled_at") @db.Timestamptz
  verifiedAt     DateTime? @map("verified_at") @db.Timestamptz
  dispensedAt    DateTime? @map("dispensed_at") @db.Timestamptz
  batchId        String?   @map("batch_id") @db.Uuid
  claimId        String?   @map("claim_id") @db.Uuid
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  item           Item?        @relation(fields: [itemId], references: [id])
  itemLot        ItemLot?     @relation(fields: [itemLotId], references: [id])
  batch          Batch?       @relation(fields: [batchId], references: [id])
  filler         User?        @relation("FillFiller", fields: [filledBy], references: [id])
  verifier       User?        @relation("FillVerifier", fields: [verifiedBy], references: [id])

  events         FillEvent[]
  claim          Claim?       @relation(fields: [claimId], references: [id])
  packingListItems PackingListItem[]
  posLineItems   PosLineItem[]
  payments       Payment[]

  @@unique([prescriptionId, fillNumber])
  @@index([status])
  @@index([externalId])
  @@map("prescription_fills")
}

model FillEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
