  item               Item?            @relation(fields: [itemId], references: [id])
  formula            Formula?         @relation(fields: [formulaId], references: [id])
  insurance          PatientInsurance? @relation(fields: [insuranceId], references: [id])
  assignee           User?            @relation("RxAssignee", fields: [assignedTo], references: [id])
  creator            User?            @relation("RxCreator", fields: [createdBy], references: [id])

  fills              PrescriptionFill[]
  statusLog          PrescriptionStatusLog[]
